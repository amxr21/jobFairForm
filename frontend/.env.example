# Frontend Environment Variables
# Copy this file to .env and pick ONE VITE_API_URL below.

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Local backend (run `npm run dev` in form/backend, listens on port 2001):
VITE_API_URL=http://localhost:2001

# Production backend (Railway) — comment the line above and uncomment this to
# point the app at prod instead:
# VITE_API_URL=https://jobfairform-backend-production.up.railway.app
