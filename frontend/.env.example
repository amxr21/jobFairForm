# Frontend Environment Variables
# Copy this file to .env and pick ONE VITE_API_URL below.

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Vite inlines this at BUILD time, so changing it on a hosting provider
# requires a REDEPLOY — restarting the service is not enough.
#
# Local backend (run `npm run dev` in form/backend, listens on port 2001):
VITE_API_URL=http://localhost:2001

# Production backend (Render) — comment the line above and uncomment this to
# point the app at prod instead. Must match the fallback in src/config/api.js
# and the host you actually deploy to.
# VITE_API_URL=https://jobfairform-backend.onrender.com
